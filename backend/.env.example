# =============================================================================
# SolarJi Backend — copy to backend/.env and fill in real values
# Never commit backend/.env (secrets stay local / in Render env dashboard)
# =============================================================================

# --- Server (required) ---
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/solarji?retryWrites=true&w=majority
JWT_SECRET=replace-with-long-random-string-min-32-chars

# Comma-separated frontend origins allowed by CORS (production + local dev)
CLIENT_URL=http://localhost:5173,https://your-frontend-domain.com

# --- Cloudinary — lead note image uploads (required for photo uploads) ---
# https://console.cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SMTP / Nodemailer — complaint confirmation emails (required for email confirmations) ---
# Gmail: enable 2FA and create an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com

# --- Upload tuning (optional — defaults shown) ---
UPLOAD_MAX_FILE_MB=10
UPLOAD_MAX_FILES=6
UPLOAD_MAX_DIMENSION=1600
UPLOAD_COMPRESSION_QUALITY=75

# --- Database seed — npm run seed (required when running seed) ---
# Passwords are hashed on the frontend before login; seed stores bcrypt(sha256(plain))
SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PHONE=+91 0000000000
