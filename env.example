# =============================================================================
# SolarJi — Environment variables reference
#
# This project uses two env files (both gitignored when copied):
#   backend/.env   ← copy from backend/.env.example
#   frontend/.env  ← copy from frontend/.env.example
#
# On Render: set the same keys in the Web Service (backend) and Static Site
# (frontend) environment dashboards.
# =============================================================================

# ─── BACKEND (backend/.env) ───────────────────────────────────────────────────

PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/solarji?retryWrites=true&w=majority
JWT_SECRET=replace-with-long-random-string-min-32-chars
CLIENT_URL=http://localhost:5173,https://your-frontend-domain.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com

UPLOAD_MAX_FILE_MB=10
UPLOAD_MAX_FILES=6
UPLOAD_MAX_DIMENSION=1600
UPLOAD_COMPRESSION_QUALITY=75

SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PHONE=+91 0000000000

# ─── FRONTEND (frontend/.env) ─────────────────────────────────────────────────

VITE_API_URL=http://localhost:5000/api
