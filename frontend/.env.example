# =============================================================================
# SolarJi Frontend — copy to frontend/.env (dev) or frontend/.env.production (build)
# Never commit .env / .env.production (gitignored)
# =============================================================================

# Backend API base URL (required — no fallback in code)
# Local development:
VITE_API_URL=http://localhost:5000/api

# Production build example:
# VITE_API_URL=https://your-api.onrender.com/api
